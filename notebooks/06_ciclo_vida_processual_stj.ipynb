        "import json\n",
        "from pathlib import Path\n",
        "from copy import deepcopy\n",
        "\n",
        "nb_path = Path(\"/content/drive/MyDrive/Mestrado/2026/llms/datajud_probe/notebooks/06_ciclo_vida_processual_stj.ipynb\")\n",
        "\n",
        "# backup\n",
        "bak_path = nb_path.with_suffix(\".ipynb.bak\")\n",
        "bak_path.write_bytes(nb_path.read_bytes())\n",
        "print(\"Backup criado:\", bak_path)\n",
        "\n",
        "with nb_path.open(\"r\", encoding=\"utf-8\") as f:\n",
        "    nb = json.load(f)\n",
        "\n",
        "# 1) remove metadata.widgets no topo\n",
        "if \"metadata\" in nb and \"widgets\" in nb[\"metadata\"]:\n",
        "    nb[\"metadata\"].pop(\"widgets\", None)\n",
        "\n",
        "# 2) limpa células\n",
        "for cell in nb.get(\"cells\", []):\n",
        "    # cell metadata widgets\n",
        "    if \"metadata\" in cell and isinstance(cell[\"metadata\"], dict):\n",
        "        cell[\"metadata\"].pop(\"widgets\", None)\n",
        "\n",
        "    # outputs widget mime\n",
        "    new_outputs = []\n",
        "    for out in cell.get(\"outputs\", []):\n",
        "        out2 = deepcopy(out)\n",
        "\n",
        "        # data dict em execute_result/display_data\n",
        "        data = out2.get(\"data\")\n",
        "        if isinstance(data, dict):\n",
        "            data.pop(\"application/vnd.jupyter.widget-view+json\", None)\n",
        "            data.pop(\"application/vnd.jupyter.widget-state+json\", None)\n",
        "            # se output ficou vazio, descarta\n",
        "            if len(data) == 0 and out2.get(\"output_type\") in (\"display_data\", \"execute_result\"):\n",
        "                continue\n",
        "\n",
        "        new_outputs.append(out2)\n",
        "\n",
        "    if \"outputs\" in cell:\n",
        "        cell[\"outputs\"] = new_outputs\n",
        "\n",
        "with nb_path.open(\"w\", encoding=\"utf-8\") as f:\n",
        "    json.dump(nb, f, ensure_ascii=False, indent=1)\n",
        "\n",
        "print(\"Notebook sanitizado:\", nb_path)"
