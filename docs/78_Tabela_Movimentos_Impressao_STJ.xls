									style='font-family:Verdana,sans-serif;font-size: 8pt;font-weight:300;' >CPC</td><td  align=left nowrap
									style='font-family:Verdana,sans-serif;font-size: 8pt;font-weight:300;' >1.031, § 2ŗ</td><td  align=right
									style='font-family:Verdana,sans-serif;font-size: 8pt;font-weight:300;width:150px;' >2022-06-01 00:00:00</td><td  align=right
